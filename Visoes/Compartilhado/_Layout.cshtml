<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Titulo"] - Apoio Escolar</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='20' fill='%230070f3'/%3E%3Ctext x='50' y='50' font-family='Arial' font-size='45' font-weight='bold' fill='white' text-anchor='middle' dominant-baseline='central'%3EAE%3C/text%3E%3C/svg%3E">
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="app-nav">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span>AE</span>
                Apoio Escolar
            </a>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Início</a>
                <a asp-controller="Cursos" asp-action="Index">Disciplinas</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index">Admin</a>
                }
            </div>
            <div class="account-area">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span>Olá, @User.Identity.Name</span>
                    <form asp-controller="Conta" asp-action="Logout" method="post">
                        <button type="submit">Sair</button>
                    </form>
                }
                else
                {
                    <a class="login-link" asp-controller="Conta" asp-action="Login">Entrar</a>
                }
            </div>
        </nav>
    </header>

    <div class="page-shell">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <span>Plataforma Ensino Fundamental</span>
        <span>Apoio Escolar Virtual</span>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
